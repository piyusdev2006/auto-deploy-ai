# ─────────────────────────────────────────────────────────────
# AutoDeploy AI — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/autodeploy?retryWrites=true&w=majority

# Session secret (generate a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Encryption key for GitHub access tokens (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# LLM Provider: "gemini" (default) or "groq"
LLM_PROVIDER=gemini
# Google AI Studio key (for Gemini 1.5 Flash)
GOOGLE_API_KEY=
# Groq API key (alternative provider)
GROQ_API_KEY=
# Model overrides (optional — sensible defaults are built in)
# GEMINI_MODEL=gemini-1.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile

# ── AWS / VPS Configuration ──────────────────────────────────────────────
# Public IPv4 of your EC2 instance (or any Linux VPS)
VPS_IP=

# SSH username — AWS Ubuntu AMIs default to 'ubuntu'
VPS_USERNAME=ubuntu

# Path to your .pem private key file (relative to server/ or absolute)
# NEVER commit this file — it is listed in .gitignore
SSH_KEY_PATH=./aws-key.pem

# GitHub Webhook secret (must match the secret configured in your repo's webhook settings)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# Frontend URL (for CORS & redirects)
CLIENT_URL=http://localhost:5173
