# ─────────────────────────────────────────────────────────────
# server/.gitignore — Backend (Express / Node.js)
# ─────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment / Secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ── SSH / Cloud credentials ──────────────────────────────────
*.pem
*.key
*.ppk

# ── Logs ──────────────────────────────────────────────────────
*.log

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/

# ── Test coverage ────────────────────────────────────────────
coverage/