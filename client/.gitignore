# ─────────────────────────────────────────────────────────────
# client/.gitignore — Frontend (Vite / React)
# ─────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment / Secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ── Build outputs ─────────────────────────────────────────────
dist/
dist-ssr/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.local

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
